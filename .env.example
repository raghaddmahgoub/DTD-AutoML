# Copy to .env and fill in your key:
#   cp .env.example .env

# Required for LLM steps (EDA, plan_training, controller)
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional — defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Optional — Optuna trials when using train_simple_optuna
# AUTOML_OPTUNA_TRIALS=30
